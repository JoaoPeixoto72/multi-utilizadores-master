{
  "extends": "./.svelte-kit/tsconfig.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ESNext",
    "noEmit": true,
    "types": ["@cloudflare/workers-types"],
    "skipLibCheck": true
  },
  "include": ["src/**/*", ".svelte-kit/types/**/*", "../../worker-configuration.d.ts"],
  "exclude": ["node_modules", "src/worker.ts", "src/lib/paraglide/server.js"]
}
