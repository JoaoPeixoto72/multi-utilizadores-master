{
  "name": "cf-base",
  "private": true,
  "version": "0.1.0",
  "description": "Boilerplate multi-empresa SaaS — Cloudflare Workers + SvelteKit + Hono",
  "engines": {
    "node": ">=24.14.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "check": "turbo run check",
    "deploy:web": "pnpm --filter {apps/web} deploy",
    "deploy:web:full": "pnpm --filter {apps/web} build && pnpm --filter {apps/web} run deploy",
    "deploy:api": "pnpm --filter {apps/api} deploy",
    "deploy:api:full": "pnpm --filter {apps/api} build && pnpm --filter {apps/api} run deploy"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@playwright/test": "1.58.2",
    "turbo": "2.8.17",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
