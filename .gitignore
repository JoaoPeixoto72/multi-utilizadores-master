# .gitignore — cf-base (pnpm + turbo + wrangler)

# Dependências
node_modules/
.pnpm-store/

# Build outputs
.svelte-kit/
dist/
*.tsbuildinfo

# Caches
.turbo/
.vite/
.wrangler/

# Secrets — NUNCA commitar
.dev.vars
**/.dev.vars

# Gerado por wrangler (commitar worker-configuration.d.ts)
# worker-configuration.d.ts  ← NÃO ignorar — commitar

# Logs
*.log
pnpm-debug.log*

# OS
.DS_Store
Thumbs.db

# IDEs
.vscode/
.idea/
*.swp
*.swo

# Playwright
test-results/
playwright-report/
e2e/.auth/
apps/web/e2e/.auth/
apps/web/e2e-results.json
e2e-results.json

# Coverage
coverage/
.nyc_output/

# GitHub (se não usar)
.github/

# Ficheiros temporários gerados
apps/web/*.txt
apps/web/check*.json
